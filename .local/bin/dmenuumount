#!/bin/sh

. utils

freemount() {
	if fuser -m "$1" >/dev/null 2>&1; then
		[ $(prompt 'Mount is busy. Kill processes?' $'No\nYes') = "Yes" ] || return 1
		sudo -A fuser -km "$1"
	fi
}

unmountdrive() {
	if [ -z "$chosen" ]; then
		drives=$(lsblk -nrpo "mountpoint,size" | awk '$1!~/\/boot|\/$/&&length($2)>1{printf "%s (%s)\n",$1,$2}')
		[ -z "$drives" ] && quit "No mounted drives found"
		chosen="$(prompt 'Unmount which drive?' "$drives")" || exit 1
		chosen="$(echo "$chosen" | awk '{print $1}')"
	fi
	drive=($(lsblk -nrpo "mountpoint,name,type" | awk -v chosen="$chosen" '$1==chosen{print $2, $3}'))

	if mount | grep -F -q " on $chosen "; then
		freemount "$chosen" || quit "Failed to free mount point"
		sudo -A umount "$chosen" || quit "Failed to unmount"
	fi

	if ! find "$chosen" -type f -print -quit | grep -q . && \
			! find "$chosen" -mindepth 1 -type d -exec mountpoint -q {} -print -quit | grep -q .; then
		rm -rf -- "$chosen"
	else
		quit "$chosen is not empty"
	fi

	end $? "Unmounting"
	if [ "${drive[1]}" == "crypt" ]; then
		sudo -A cryptsetup close "${drive[0]}"
		end $? "Locking"
	fi
}

unmountandroid() {
	chosen="$(prompt 'Unmount which device?' "$(awk '/simple-mtpfs/ {print $2}' /etc/mtab)")" || exit 1
	[ -z "$chosen" ] && exit
	sudo -A umount -l "$chosen"
	end $? "Unmounting"
}

umountssh() {
	chosen="$(prompt 'Unmount:' "$(mount | grep "$1" | awk '{print $3}')")"
	[ -z "$chosen" ] && exit
	fusermount -u "$chosen"
	end $? "Unmounting"
}

unmountcloud() {
	clouds=$(mount | awk '/fuse.rclone/ {print $3 " (" $1 ")"}')
	[ -z "$clouds" ] && quit "No cloud mounts found"

	chosen="$(prompt 'Unmount which cloud?' "$clouds")" || exit 1
	mnt="${chosen%% *}"

	freemount "$mnt" || quit "Failed to free mount point"

	fusermount -u "$mnt" || quit "Failed to unmount cloud"

	end $? "Unmounting cloud"
}

asktype() {
	choice="$(prompt 'Unmount:' $'Drive\nAndroid\nSSH\nCloud')" || exit 1
	case "$choice" in
		Drive) unmountdrive ;;
		Android) unmountandroid ;;
		SSH) umountssh "fuse.sshfs" ;;
		Cloud) unmountcloud ;;
	esac
}

end() {
	case $1 in
		0) notify "$2" "$2 successful" ;;
		*) notify "$2" "$2 failed" ;;
	esac
}

if [ -z "$1" ]; then
	asktype
else
	chosen=$(realpath "$1")
	unmountdrive
fi
