#!/bin/sh

cmd=$1
mods=${2-}

if [ -n "$mods" ]; then
	[ -d "$XDG_DATA_HOME/venv" ] || python3 -m venv "$XDG_DATA_HOME/venv"
	. "$XDG_DATA_HOME/venv/bin/activate"

	for m in $mods; do
		pip install --quiet "$m" 2>/dev/null
	done
fi

if command -v "$cmd" >/dev/null 2>&1; then
	exec "$cmd"
else
	exec python "$cmd"
fi
