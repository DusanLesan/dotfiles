{
	"window": {
		"title": "${dirty}${activeEditorShort}",
		"menuBarVisibility": "toggle",
		"density.editorTabHeight": "compact",
		"customTitleBarVisibility": "never",
		"titleBarStyle": "native"
	},
	"workbench": {
		"startupEditor": "none",
		"secondarySideBar": {
			"defaultVisibility": "hidden"
		},
		"colorTheme": "Dark Modern",
		"colorCustomizations": {
			"sideBar.background": "#181818",
			"editor.background": "#181818"
		}
	},
	"editor": {
		"fontFamily": "'monospace', monospace",
		"snippetSuggestions": "top",
		"renderWhitespace": "all",
		"lineNumbers": "relative",
		"minimap": { "enabled": false },
		"fontLigatures": true
	},
	"files": {
		"enableTrash": false,
		"trimTrailingWhitespace": true,
		"insertFinalNewline": true,
		"trimFinalNewlines": true
	},
	"terminal": {
		"integrated": {
			"enablePersistentSessions": false,
			"persistentSessionReviveProcess": "never",
			"scrollback": 100000
		}
	},
	"task.allowAutomaticTasks": "on",
	"explorer.confirmDelete": false,
	"search.exclude": {
		"**/components/AviaLibrary": true,
		"**/components/kochava": true,
		"**/components/OTPublishersSDK": true,
		"**/components/redfast": true,
		"**/components/youbora": true,
		"cicd/automation": true
	},
	"update": {
		"mode": "none",
		"showReleaseNotes": false
	},
	"extensions.ignoreRecommendations": true,
	"npm.packageManager": "npm",
	"npm.scriptRunner": "npm",
	"diffEditor.ignoreTrimWhitespace": false,
	"githubPullRequests.pullBranch": "never",
	"git.autofetch": true,
	"git.openRepositoryInParentFolders": "never",
	"gitlens.hovers.currentLine.over": "line",
	"gitlens.plusFeatures.enabled": false,
	"gitlens.statusBar.alignment": "left",
	"gitlens.currentLine.enabled": false,
	"brightscript.deviceDiscovery.enabled": false,
	"brightscript.debug.raleTrackerTaskFileLocation": "/tmp/TrackerTask.xml",
	"brightscript.debug.fileLogging.dir": "/tmp/brightscriptLog",
	"redhat.telemetry.enabled": false,
	"maven.settingsFile": "/home/dusan/.config/maven/settings.xml",
	"java.configuration.maven.userSettings": "/home/dusan/.config/maven/settings.xml",
	"extensions.experimental.affinity": {
		"asvetliakov.vscode-neovim": 1
	},
	"vscode-neovim": {
		"neovimInitVimPaths.linux": "/home/dusan/.config/nvim/init.lua",
		"ctrlKeysForNormalMode": [
			"a", "b", "d", "e", "h", "i", "j", "k", "l", "m", "n", "o", "r", "t", "u", "w", "y", "z",
			"]", "right", "left", "up", "down", "backspace", "delete"
		],
		"compositeKeys": {
			"jk": {
				"command": "vscode-neovim.escape"
			}
		},
		"afterInitConfig": [
			"lua vim.diagnostic.config({virtual_text=false})",
			"set ve=onemore"
		]
	},
	"chat.tools.terminal.autoApprove": {
		"/[;&`]|\\|\\||\\$\\(/": { "approve": false, "matchCommandLine": true },
		"/^gh\\s+(issue|pr|repo|release|run|workflow|gist|label|ruleset|secret|variable|org|project|codespace|cache)\\s+(list|view|status)\\b/": { "approve": true, "matchCommandLine": true },
		"/^gh\\s+(search|status|browse)\\b/": { "approve": true, "matchCommandLine": true },
		"/^git\\s+(status|log|show|diff|blame|rev-parse|rev-list|ls-files|ls-tree|for-each-ref|describe|shortlog|reflog|cat-file|grep|stash\\s+list|stash\\s+show|config\\s+--get|config\\s+--list)\\b/": { "approve": true, "matchCommandLine": true },
		"/^git\\s+(branch|tag|remote)(\\s+(-l|--list|-v|--verbose|-a|--all|-r|--remotes))*\\s*$/": { "approve": true, "matchCommandLine": true },
		"/^find\\b(?!.*(-delete|-exec|-execdir|-ok|-okdir|-fprint|-fprintf|-fls))/": { "approve": true, "matchCommandLine": true },
		"cat": true, "head": true, "tail": true, "wc": true, "file": true, "stat": true, "ls": true, "realpath": true, "readlink": true,
		"which": true, "whereis": true, "type": true, "rg": true, "grep": true, "diff": true, "cmp": true, "jq": true, "bat": true
	}
}
