#!/bin/sh

. utils

getchoice() {
	drives="$(lsblk -rpo 'name,size,type,fstype,mountpoint' | \
		{ [ -n "$2" ] && grep -Ev "$2" || cat; } | grep "$1" | sed "s/ /:/g" | \
		awk -F ':' '$4!="" && $5=="" {printf "%s (%s)\n", $1, $2}')"
	chosen="$(prompt 'Mount which drive?' "$drives" )" || exit 1
	if [ -z "$chosen" ]; then
		getchoice "$1" "$2"
	else
		chosen="${chosen%% *}"
	fi
}

getmount() {
	mnt="$(prompt 'Mount point?' "$1")" || exit 1
	[ ! -d "$mnt" ] && mkdir -p "$mnt"
}

mountdrive() {
	getchoice 'part\|rom\|crypt\|disk' 'crypto_LUKS'
	getmount "$HOME/mnt$chosen"
	sudo -A mount "$chosen" "$mnt"
	end $?
}

open() {
	[ -b "/dev/mapper/$name" ] && return 0
	key="$(getpass "Drive passphrase or key path: ")" || exit 1
	if [ -f "$key" ]; then
		sudo -A cryptsetup open $chosen $name --key-file $key && return 0
	else
		sudo -A cryptsetup open $chosen $name <<< "$key" && return 0
	fi
	open
}

getname() {
	name="$(prompt "$1")" || exit 1
	[ -e /dev/mapper/$name ] && getname "Name already exists or empty. Name: "
}

decrypt() {
	if [ -z "$chosen" ]; then
		unlocked
		getchoice 'crypto_LUKS' "$unlocked_devices"
		getname "Name: "
		getmount "$HOME/mnt/dev/mapper/$name"
	fi
	open
	sudo -A mount "/dev/mapper/$name" "$mnt"
	end $?
}

unlocked() {
	for device in $(readlink /dev/mapper/*); do
		[ -n "$unlocked_devices" ] && unlocked_devices+="|"
		unlocked_devices+="$(ls -1 "/sys/block/${device##[./]}/slaves")"
	done
}

mountssh() {
	host="$(prompt 'Mount which host?' "$(grep -P "^Host ([^*]+)$" $HOME/.ssh/config | sed 's/Host //')")" || exit 1
	target="$(prompt 'Target mount point?')"
	getmount "$HOME/mnt/$host"
	sshfs $host:$target $mnt -o follow_symlinks
	end $?
}

mountcloud() {
	dir="$XDG_DATA_HOME/cloud"

	files="$(find "$dir" -maxdepth 1 -name '*.gpg' -printf '%f\n' | sed 's/\.gpg$//')"

	sel="$(prompt 'Mount which cloud?' "$files")" || exit 1
	file="$dir/$sel.gpg"

	eval "$(gpg2 --quiet --decrypt "$file")" || exit 1

	default="$HOME/mnt/$sel"
	getmount "$default"

	rclone mount "$REMOTE" "$mnt" \
		--vfs-cache-mode writes \
		--config /dev/null &
	end $?
}

mountandroid() {
	getmount "$HOME/mnt"
	jmtpfs "$mnt"
	end $?
}

asktype() {
	choice="$(prompt 'Mount:' $'Drive\nSSH\nCrypt\nAndroid\nCloud')" || exit 1
	case "$choice" in
		Drive) mountdrive ;;
		SSH) mountssh ;;
		Crypt) decrypt ;;
		Android) mountandroid ;;
		Cloud) mountcloud ;;
	esac
}

end() {
	if [ "$1" -eq 0 ]; then
		notify "Mounting" "Mounted at $mnt"
	else
		notify "Mounting" "Mounting failed!"
		[ -z "$(ls -A $mnt)" ] && rm -rf "$mnt"
	fi
	exit $1
}

gettarget() {
	drives="$(lsblk -rpo 'name,size,type,fstype,mountpoint' |
		awk '$3 ~ /part|disk/ && $4 != "crypto_LUKS" && $5=="" {printf "drive:%s (%s)\n",$1,$2}')"

	luks="$(lsblk -rpo 'name,size,type,fstype,mountpoint' |
		awk '$4=="crypto_LUKS" {printf "crypt:%s (%s)\n",$1,$2}')"

	hosts="$(grep -P "^Host ([^*]+)$" "$HOME/.ssh/config" 2>/dev/null |
		sed 's/^Host /ssh:/')"

	clouds="$(find "$XDG_DATA_HOME/cloud" -maxdepth 1 -name '*.gpg' -printf 'cloud:%f\n' |
		sed 's/\.gpg$//')"

	targets="$(printf "%s\n%s\n%s\n%s\nAndroid\n" \
		"$drives" "$luks" "$hosts" "$clouds")"

	chosen="$(prompt 'Mount:' "$targets")" || exit 1
}

mountauto() {
	case "$chosen" in
		drive:*)
			dev="${chosen#drive:}"
			dev="${dev%% *}"
			getmount "$HOME/mnt$dev"
			sudo -A mount "$dev" "$mnt"
			;;

		crypt:*)
			chosen="${chosen#crypt:}"
			chosen="${chosen%% *}"
			getname "Name: "
			getmount "$HOME/mnt/dev/mapper/$name"
			open
			sudo -A mount "/dev/mapper/$name" "$mnt"
			;;

		ssh:*)
			host="${chosen#ssh:}"
			target="$(prompt 'Target path?')"
			getmount "$HOME/mnt/$host"
			sshfs "$host:$target" "$mnt" -o follow_symlinks
			;;

		cloud:*)
			name="${chosen#cloud:}"
			file="$XDG_DATA_HOME/cloud/$name.gpg"

			eval "$(gpg2 --quiet --decrypt "$file")" || exit 1

			getmount "$HOME/mnt/$name"
			echo "Mounting $REMOTE at $mnt"

			rclone mount "$REMOTE" "$mnt" \
				--vfs-cache-mode writes \
				--config /dev/null &
			;;

		Android)
			getmount "$HOME/mnt"
			jmtpfs "$mnt"
			;;
	esac

	end $?
}

if [ -z "$1" ]; then
	gettarget
	mountauto
else
	chosen="$1"
	ext="${chosen##*.}"
	name="a-$(basename "$chosen" | sed "s/.$ext//")"
	mnt="$(pwd)/$name"
	[ ! -d "$mnt" ] && mkdir -p "$mnt"
	if cryptsetup isLuks "$chosen"; then
		decrypt
	else
		sudo -A mount "$chosen" "$mnt"
	fi
fi
