#!/usr/bin/env python3

import os
import re
import sys
import tempfile
from pathlib import Path
from urllib.parse import quote

_PATH_VAR_NAMES = (
	"XDG_CONFIG_HOME",
	"XDG_CACHE_HOME",
	"XDG_STATE_HOME",
	"XDG_DATA_HOME",
	"HOME",
	"PWD",
)

_PATH_TAIL = r"(?:/[^\s]*)?"

_LONG_ARG_RE = re.compile(
	r"(?<!\$)(?<![A-Za-z0-9._/-])(?:(?:old|new)/)?(?=[A-Za-z0-9][A-Za-z0-9._-]*[_-])"
	r"([A-Za-z0-9][A-Za-z0-9._-]{38,}[A-Za-z0-9])(?:/)?(?=\s|$)"
)

def load_secret_redactions(priv_path: Path, min_len: int = 8) -> list[tuple[str, str]]:
	key_to_val: dict[str, str] = {}

	if not priv_path.is_file():
		return []

	try:
		lines = priv_path.read_text(encoding="utf-8", errors="replace").splitlines()
	except OSError:
		return []

	for line in lines:
		line = line.strip()
		if not line or line.startswith("#"):
			continue

		m = re.match(r"^(?:export\s+)?([A-Za-z_][A-Za-z0-9_]*)=(.*)$", line)
		if not m:
			continue

		key, val = m.group(1), m.group(2).strip()

		if len(val) >= 2 and val[0] == val[-1] and val[0] in "\"'":
			val = val[1:-1]

		if len(val) >= min_len:
			key_to_val[key] = val

	pairs: list[tuple[str, str]] = []

	for k, v in key_to_val.items():
		pairs.append((v, k))

		enc = quote(v, safe="")
		if enc != v and len(enc) >= min_len:
			pairs.append((enc, k))

	pairs.sort(key=lambda vk: len(vk[0]), reverse=True)

	return pairs

def redact_secret_values(line: str, pairs: list[tuple[str, str]]) -> str:
	for val, key in pairs:
		line = line.replace(val, f"${key}")

	return line

def _strip_line_continuation(s: str) -> str:
	t = s.rstrip("\n\r")

	while t.rstrip().endswith("\\"):
		t = t.rstrip()[:-1]

	return t.rstrip()

def _collapse_ws(s: str) -> str:
	return re.sub(r"\s+", " ", s).strip()

def join_backslash_continuations(raw_lines: list[str]) -> list[str]:
	out: list[str] = []
	buf: list[str] = []

	for line in raw_lines:
		s = line.rstrip("\n\r")

		if s.rstrip().endswith("\\"):
			buf.append(_strip_line_continuation(s))
			continue

		if buf:
			buf.append(s.lstrip())
			merged = " ".join(p for p in buf if p)
			merged = _strip_line_continuation(merged)
			merged = _collapse_ws(merged)
			out.append(merged)
			buf = []
		else:
			one = _strip_line_continuation(s)
			one = _collapse_ws(one)
			out.append(one)

	if buf:
		merged = " ".join(p for p in buf if p)
		merged = _strip_line_continuation(merged)
		merged = _collapse_ws(merged)
		out.append(merged)

	return out

def write_history(path: Path, text: str) -> None:
	path = path.resolve()
	parent = path.parent
	fd, tmp = tempfile.mkstemp(dir=str(parent), prefix=f".{path.name}.", suffix=".tmp")
	tmp_path = Path(tmp)
	try:
		with os.fdopen(fd, "w", encoding="utf-8", newline="\n") as f:
			f.write(text)
			f.flush()
			try:
				os.fsync(f.fileno())
			except OSError:
				pass
		os.replace(tmp_path, path)
	except BaseException:
		try:
			tmp_path.unlink(missing_ok=True)
		except OSError:
			pass
		raise

def is_invalid_or_junk(line: str) -> bool:
	s = line.strip()

	if not s:
		return True

	return any(ord(c) < 32 and c != "\t" for c in s)

def normalize_paths_for_dedup(s: str) -> str:
	p = "$P"

	for name in _PATH_VAR_NAMES:
		esc = re.escape(name)
		s = re.sub(r"\$\{" + esc + r"\}" + _PATH_TAIL, p, s)
		s = re.sub(r"\$" + esc + _PATH_TAIL, p, s)

	s = re.sub(r"~/[^\s]*", p, s)
	s = re.sub(r"(?<![\w/])~(?=/|\s|$)", p, s)

	s = re.sub(
		r"(?:^|(?<=\s))/[A-Za-z0-9._+-]+(?:/[A-Za-z0-9._+-]+)*(?=\s|$)",
		p,
		s,
	)

	return s

def normalize_for_dedup(line: str) -> str:
	s = normalize_paths_for_dedup(line.strip())
	s = re.sub(
		r'(?<![\w/])(["\']?)(https?://[^\s"\'<>]+)\1',
		"$URL",
		s,
		flags=re.I,
	)

	s = re.sub(r"\b(?:\d{1,3}\.){3}\d{1,3}\b", "$IP", s)
	s = re.sub(r"(?:[A-Fa-f0-9]{2}:){5}[A-Fa-f0-9]{2}", "$MAC", s)
	s = re.sub(
		r"\b[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}\b",
		"$UUID",
		s,
		flags=re.I,
	)
	s = re.sub(r"\b[a-f0-9]{32,}\b", "$HASH", s)

	s = _LONG_ARG_RE.sub("$L", s)

	s = re.sub(r'"[^"]*"', '"$Q"', s)
	s = re.sub(r"'[^']*'", "'$Q'", s)
	s = re.sub(r"(?<!\$)\b[A-Za-z0-9]+(?:[_-][A-Za-z0-9]+){2,}\b", "$SLUG", s)

	s = re.sub(r"\s+", " ", s).strip()

	return s

def keep_last_index(lines: list[str], key_fn) -> list[str]:
	last_i: dict[str, int] = {}

	for i, line in enumerate(lines):
		k = key_fn(line)
		if k:
			last_i[k] = i

	out: list[str] = []

	for i, line in enumerate(lines):
		k = key_fn(line)
		if not k:
			continue
		if last_i[k] == i:
			out.append(line)

	return out

def main() -> None:
	if len(sys.argv) != 2:
		print("usage: clean-history <history-file>", file=sys.stderr)
		sys.exit(1)

	path = Path(sys.argv[1]).resolve()
	priv = (Path(os.environ["XDG_DATA_HOME"]).expanduser().resolve() / "secrets" / "priv").resolve()
	redactions = load_secret_redactions(priv)

	raw = path.read_text(encoding="utf-8", errors="replace").splitlines()
	merged = join_backslash_continuations(raw)

	kept: list[str] = []

	for line in merged:
		if is_invalid_or_junk(line):
			continue

		line = redact_secret_values(line.rstrip("\n"), redactions)
		kept.append(line)

	kept = keep_last_index(kept, lambda s: s if s.strip() else "")

	survivors = keep_last_index(kept, normalize_for_dedup)

	text = "\n".join(survivors)
	if survivors:
		text += "\n"

	write_history(path, text)

	print(f"{path}: lines {len(raw)} -> {len(survivors)}", file=sys.stderr)

if __name__ == "__main__":
	main()
